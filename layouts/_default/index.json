[
  {{- $docs := where .Site.Pages "Section" "docs" -}}
  {{- $base := $.Site.Params.s3_url | default "" -}}
  {{- $base = strings.TrimSuffix "/" $base -}}

  {{- $first := true -}}

  {{- range $docs -}}

    {{- if not $first }},{{ end -}}
    {{- $first = false -}}

    {{- /* Maps metadata */ -}}
    {{- $maps := .Params.maps | default (slice) -}}
    {{- $jaar := "" -}}
    {{- $categorie := "" -}}
    {{- $zaak := "" -}}

    {{- if ge (len $maps) 1 -}}
      {{- $jaar = index $maps 0 -}}
    {{- end -}}
    {{- if ge (len $maps) 2 -}}
      {{- $categorie = index $maps 1 -}}
    {{- end -}}
    {{- if ge (len $maps) 3 -}}
      {{- $zaak = index $maps 2 -}}
    {{- end -}}

    {{- /* SAFE file path handling (FIX: .File can be nil) */ -}}
    {{- $full_path := "" -}}
    {{- with .File -}}
      {{- $full_path = .Path -}}
    {{- end -}}

    {{- $cleaned_path := strings.TrimPrefix "docs/" $full_path -}}
    {{- $pdf_path := replace $cleaned_path ".md" ".pdf" -}}
    {{- $pdf_path = strings.TrimPrefix "/" $pdf_path -}}

    {{- $pdf_url := printf "%s/%s" $base $pdf_path -}}

    {
      "objectID": {{ .Permalink | jsonify }},
      "title": {{ .Title | jsonify }},
      "content": {{ .Plain | jsonify }},
      "jaar": {{ $jaar | jsonify }},
      "categorie": {{ $categorie | jsonify }},
      "zaak": {{ $zaak | jsonify }},
      "publicatiedatum": {{ if .Date }}{{ .Date.Format "02-01-2006" | jsonify }}{{ else }}{{ "" | jsonify }}{{ end }},
      "pdf_url": {{ $pdf_url | jsonify }},
      "relpermalink": {{ .RelPermalink | jsonify }},
      "type": "document"
    }

  {{- end -}}
]
