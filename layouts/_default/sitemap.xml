{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {{ range .Data.Pages }}
    <url>
      {{ if eq .Kind "page" }}
        {{/* Dit genereert de directe S3 link voor de sitemap */}}
        <loc>https://publicaties-coevorden.s3.eu-north-1.amazonaws.com/pdf+bestanden/{{ .File.BaseFileName }}.pdf</loc>
      {{ else }}
        <loc>{{ .Permalink }}</loc>
      {{ end }}
      <lastmod>{{ safeHTML ( .Lastmod.Format "2006-01-02T15:04:05-07:00" ) }}</lastmod>
      <changefreq>weekly</changefreq>
      <priority>{{ if .IsHome }}1.0{{ else }}0.5{{ end }}</priority>
    </url>
  {{ end }}
</urlset>
